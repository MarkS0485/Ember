<Window x:Class="Ember.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:c="clr-namespace:Ember.Ui.Controls"
        Title="Ember"
        Background="{StaticResource Body0}"
        FontFamily="Segoe UI" FontSize="12"
        Width="1100" Height="750"
        MinWidth="900" MinHeight="600">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Thin app bar with brand gradient + live status -->
        <Border Grid.Row="0" Background="{StaticResource BrandTopBarBrush}" Padding="14,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Ember"
                           FontSize="14" FontWeight="SemiBold" Foreground="White"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" x:Name="StatusInline"
                           Foreground="#CCFFFFFF" Margin="14,0,0,0"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" x:Name="HeroTempInline"
                           Foreground="White" FontWeight="SemiBold" FontSize="14"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Body: left rail + content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource Body1}"
                    BorderBrush="{StaticResource LineGrey}" BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="RailItems" Margin="0,8">
                        <TextBlock Text="OPERATE" Style="{StaticResource SectionHeader}" Margin="12,4,0,2"/>
                        <ToggleButton x:Name="NavDevice"   Style="{StaticResource NavRailButton}" Click="OnNav"
                                      Tag="device">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xEDB1;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0"/>
                                <TextBlock Text="Device"/>
                            </StackPanel>
                        </ToggleButton>
                        <ToggleButton x:Name="NavScan"     Style="{StaticResource NavRailButton}" Click="OnNav"
                                      Tag="scan">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE701;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0"/>
                                <TextBlock Text="Scan / pair"/>
                            </StackPanel>
                        </ToggleButton>
                        <ToggleButton x:Name="NavSchedule" Style="{StaticResource NavRailButton}" Click="OnNav"
                                      Tag="schedule">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0"/>
                                <TextBlock Text="Schedule"/>
                            </StackPanel>
                        </ToggleButton>
                        <ToggleButton x:Name="NavAuto"     Style="{StaticResource NavRailButton}" Click="OnNav"
                                      Tag="auto">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE945;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0"/>
                                <TextBlock Text="Auto Start/Stop"/>
                            </StackPanel>
                        </ToggleButton>
                        <ToggleButton x:Name="NavGroups"   Style="{StaticResource NavRailButton}" Click="OnNav"
                                      Tag="groups">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0"/>
                                <TextBlock Text="Groups"/>
                            </StackPanel>
                        </ToggleButton>

                        <TextBlock Text="CONFIGURE" Style="{StaticResource SectionHeader}" Margin="12,12,0,2"/>
                        <ToggleButton x:Name="NavSwitches" Style="{StaticResource NavRailButton}" Click="OnNav"
                                      Tag="switches">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE92F;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0"/>
                                <TextBlock Text="Switches"/>
                            </StackPanel>
                        </ToggleButton>
                        <ToggleButton x:Name="NavAdvance"  Style="{StaticResource NavRailButton}" Click="OnNav"
                                      Tag="advance">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0"/>
                                <TextBlock Text="Advanced"/>
                            </StackPanel>
                        </ToggleButton>
                        <ToggleButton x:Name="NavTimerRO"  Style="{StaticResource NavRailButton}" Click="OnNav"
                                      Tag="timer">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE823;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0"/>
                                <TextBlock Text="Heater timer"/>
                            </StackPanel>
                        </ToggleButton>

                        <TextBlock Text="DIAGNOSE" Style="{StaticResource SectionHeader}" Margin="12,12,0,2"/>
                        <ToggleButton x:Name="NavTest"     Style="{StaticResource NavRailButton}" Click="OnNav"
                                      Tag="test">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE9F5;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0"/>
                                <TextBlock Text="Test mode"/>
                            </StackPanel>
                        </ToggleButton>
                        <ToggleButton x:Name="NavFlags"    Style="{StaticResource NavRailButton}" Click="OnNav"
                                      Tag="flags">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0"/>
                                <TextBlock Text="Active flags"/>
                            </StackPanel>
                        </ToggleButton>
                        <ToggleButton x:Name="NavDebug"    Style="{StaticResource NavRailButton}" Click="OnNav"
                                      Tag="debug">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xEBE8;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0"/>
                                <TextBlock Text="Debug box"/>
                            </StackPanel>
                        </ToggleButton>
                        <ToggleButton x:Name="NavCmd"      Style="{StaticResource NavRailButton}" Click="OnNav"
                                      Tag="cmd">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE756;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0"/>
                                <TextBlock Text="Test commands"/>
                            </StackPanel>
                        </ToggleButton>
                        <ToggleButton x:Name="NavAlt"      Style="{StaticResource NavRailButton}" Click="OnNav"
                                      Tag="alt">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE909;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0"/>
                                <TextBlock Text="Altitude probe"/>
                            </StackPanel>
                        </ToggleButton>

                        <TextBlock Text="REMOTE" Style="{StaticResource SectionHeader}" Margin="12,12,0,2"/>
                        <ToggleButton x:Name="NavApi"     Style="{StaticResource NavRailButton}" Click="OnNav"
                                      Tag="api">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE968;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0"/>
                                <TextBlock Text="API server"/>
                            </StackPanel>
                        </ToggleButton>

                        <TextBlock Text="REFERENCE" Style="{StaticResource SectionHeader}" Margin="12,12,0,2"/>
                        <ToggleButton x:Name="NavMenuRef"  Style="{StaticResource NavRailButton}" Click="OnNav"
                                      Tag="menuref">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE82D;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0"/>
                                <TextBlock Text="Menu reference"/>
                            </StackPanel>
                        </ToggleButton>
                        <ToggleButton x:Name="NavAbout"    Style="{StaticResource NavRailButton}" Click="OnNav"
                                      Tag="about">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0"/>
                                <TextBlock Text="About"/>
                            </StackPanel>
                        </ToggleButton>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Content area: shows the currently-selected destination, or
                 a pushed sub-page (Group detail, Bind detail) over the top. -->
            <Grid Grid.Column="1">
                <ContentControl x:Name="ContentHost"/>
                <ContentControl x:Name="OverlayHost" Visibility="Collapsed"
                                Background="{StaticResource Body0}"/>
            </Grid>
        </Grid>

        <!-- Bottom status bar -->
        <Border Grid.Row="2" Background="{StaticResource Body1}"
                BorderBrush="{StaticResource LineGrey}" BorderThickness="0,1,0,0"
                Padding="12,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="StatusBarText" Style="{StaticResource Caption}"/>
                <TextBlock Grid.Column="1" x:Name="LastRxText" Style="{StaticResource Caption}" Margin="0,0,12,0"/>
                <TextBlock Grid.Column="2" x:Name="CurrentMacText" Style="{StaticResource Mono}" FontSize="11"
                           Foreground="{StaticResource InkLo}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
