<UserControl x:Class="Ember.Ui.Controls.PageHeader"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="self">
    <Grid Margin="0,0,0,10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0">
            <TextBlock Text="{Binding Title, ElementName=self}"
                       FontSize="18" FontWeight="SemiBold"
                       Foreground="{StaticResource InkHi}"/>
            <TextBlock Text="{Binding Subtitle, ElementName=self}"
                       FontSize="11" Foreground="{StaticResource InkLo}"
                       TextWrapping="Wrap"
                       Visibility="{Binding HasSubtitle, ElementName=self,
                           Converter={StaticResource BoolToVis}}"/>
        </StackPanel>
        <ContentPresenter Grid.Column="1" Content="{Binding ActionContent, ElementName=self}"
                          VerticalAlignment="Center"/>
    </Grid>
</UserControl>
