<Window x:Class="Ember.Ui.Dialogs.TimeRangeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add event"
        Background="{StaticResource Body0}"
        WindowStartupLocation="CenterOwner"
        SizeToContent="Height" Width="320"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="On time" Style="{StaticResource H2}" Margin="0,0,0,6"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="OnHour" Text="06" PreviewTextInput="Numeric"
                         FontSize="20" HorizontalContentAlignment="Center" Padding="6"/>
                <TextBlock Grid.Column="1" Text=":" FontSize="22"
                           VerticalAlignment="Center" Margin="4,0"/>
                <TextBox Grid.Column="2" x:Name="OnMin" Text="00" PreviewTextInput="Numeric"
                         FontSize="20" HorizontalContentAlignment="Center" Padding="6"/>
            </Grid>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,14,0,0">
            <TextBlock Text="Off time" Style="{StaticResource H2}" Margin="0,0,0,6"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="OffHour" Text="08" PreviewTextInput="Numeric"
                         FontSize="20" HorizontalContentAlignment="Center" Padding="6"/>
                <TextBlock Grid.Column="1" Text=":" FontSize="22"
                           VerticalAlignment="Center" Margin="4,0"/>
                <TextBox Grid.Column="2" x:Name="OffMin" Text="00" PreviewTextInput="Numeric"
                         FontSize="20" HorizontalContentAlignment="Center" Padding="6"/>
            </Grid>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,18,0,0">
            <Button Style="{StaticResource OutlinedButton}" Content="Cancel"
                    Click="OnCancel" Margin="0,0,8,0"/>
            <Button Style="{StaticResource PrimaryButton}" Content="Save" Click="OnSave"/>
        </StackPanel>
    </Grid>
</Window>
