<UserControl x:Class="Ember.Ui.Pages.DebugBoxPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="clr-namespace:Ember.Ui.Controls"
             xmlns:vm="clr-namespace:Ember.Ui.ViewModels"
             Background="{StaticResource Body0}">
    <UserControl.DataContext>
        <vm:DebugBoxViewModel/>
    </UserControl.DataContext>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <c:PageHeader Grid.Row="0" Title="Debug box"
                      Subtitle="Live raw BLE frames">
            <c:PageHeader.ActionContent>
                <Button Style="{StaticResource OutlinedButton}" Content="Clear"
                        Command="{Binding ClearCommand}"/>
            </c:PageHeader.ActionContent>
        </c:PageHeader>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Border Style="{StaticResource Card}">
                <ItemsControl ItemsSource="{Binding Rows}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Time}"
                                           Style="{StaticResource Mono}" FontSize="11"
                                           Foreground="{StaticResource InkLo}" Margin="0,0,8,0"/>
                                <TextBlock Grid.Column="1" Text="{Binding Dir}"
                                           Style="{StaticResource Mono}" FontSize="11"
                                           FontWeight="SemiBold" Margin="0,0,8,0"/>
                                <TextBlock Grid.Column="2" Text="{Binding Hex}"
                                           Style="{StaticResource Mono}" FontSize="11"
                                           TextWrapping="Wrap"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>
