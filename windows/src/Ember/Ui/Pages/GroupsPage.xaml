<UserControl x:Class="Ember.Ui.Pages.GroupsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="clr-namespace:Ember.Ui.Controls"
             xmlns:vm="clr-namespace:Ember.Ui.ViewModels"
             Background="{StaticResource Body0}">
    <UserControl.DataContext>
        <vm:GroupsViewModel/>
    </UserControl.DataContext>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <c:PageHeader Grid.Row="0" Title="Groups"
                      Subtitle="Control multiple heaters as one">
            <c:PageHeader.ActionContent>
                <Button Style="{StaticResource PrimaryButton}" Content="New group" Click="OnNew"/>
            </c:PageHeader.ActionContent>
        </c:PageHeader>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Style="{StaticResource Caption}" Margin="4,0,0,12"
                           Visibility="{Binding Groups.Count, Converter={StaticResource CountZeroToVis}}"
                           Text="No groups yet. Tap New in the top bar to create one."/>
                <ItemsControl ItemsSource="{Binding Groups}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource Body1}"
                                    BorderBrush="{StaticResource LineGrey}" BorderThickness="1"
                                    CornerRadius="14" Padding="16" Margin="0,0,0,8" Cursor="Hand"
                                    MouseLeftButtonUp="OnOpenGroup" Tag="{Binding Id}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Name}" Style="{StaticResource H2}"/>
                                        <TextBlock Text="{Binding MembersLabel}" Style="{StaticResource Caption}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="&#xE76C;"
                                               FontFamily="Segoe MDL2 Assets" FontSize="14"
                                               Foreground="{StaticResource InkLo}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
