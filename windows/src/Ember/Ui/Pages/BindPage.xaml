<UserControl x:Class="Ember.Ui.Pages.BindPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="clr-namespace:Ember.Ui.Controls"
             Background="{StaticResource Body0}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <c:BrandTopBar Grid.Row="0" Title="Bound heater" Subtitle="Manage this pairing" ShowBack="True"/>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16">
                <Border Style="{StaticResource Card}" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="MAC" Style="{StaticResource Caption}"/>
                        <TextBlock x:Name="MacLine" Style="{StaticResource Mono}" FontSize="14"
                                   Foreground="{StaticResource InkHi}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Display name" Style="{StaticResource H2}"/>
                        <TextBox x:Name="NameBox" Padding="8" FontSize="14" Margin="0,6,0,0"/>
                        <Button Style="{StaticResource PrimaryButton}" Content="Save name"
                                Margin="0,10,0,0" HorizontalAlignment="Right" Click="OnRename"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Unbind" Style="{StaticResource H2}"/>
                        <TextBlock Style="{StaticResource Caption}"
                                   Text="Forget this heater on this PC. Schedule, groups membership and the cached MAC are cleared."/>
                        <Button Style="{StaticResource OutlinedButton}" Content="Unbind"
                                Margin="0,10,0,0" HorizontalAlignment="Left"
                                BorderBrush="{StaticResource ErrRed}" Foreground="{StaticResource ErrRed}"
                                Click="OnUnbind"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
