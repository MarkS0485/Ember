<UserControl x:Class="Ember.Ui.Pages.DevicePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="clr-namespace:Ember.Ui.Controls"
             xmlns:vm="clr-namespace:Ember.Ui.ViewModels"
             Background="{StaticResource Body0}">

    <UserControl.DataContext>
        <vm:DeviceViewModel/>
    </UserControl.DataContext>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header row -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Device" Style="{StaticResource H1}"/>
                <TextBlock Text="Live status and control" Style="{StaticResource Caption}"/>
            </StackPanel>
            <Button Grid.Column="1" Style="{StaticResource OutlinedButton}"
                    Content="Test mode" Click="OnTestMode"
                    VerticalAlignment="Center"/>
        </Grid>

        <!-- Two-column body: hero + controls on the left, stats on the right -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT column -->
            <StackPanel Grid.Column="0" Margin="0,0,12,0">

                <!-- Status + hero strip -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding ModeLabel}" Style="{StaticResource Caption}"/>
                            <TextBlock Text="{Binding AmbientLabel}" FontSize="32" FontWeight="SemiBold"
                                       Foreground="{StaticResource InkHi}"/>
                            <TextBlock Text="ambient temperature" Style="{StaticResource Caption}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <c:StatusPill Label="{Binding StatusLabel}"
                                          Kind="{Binding StatusLabel, Converter={StaticResource StatusLabelToKind}}"
                                          HorizontalAlignment="Right"/>
                            <TextBlock Text="{Binding LastError}"
                                       Foreground="{StaticResource ErrRed}"
                                       Style="{StaticResource Caption}"
                                       HorizontalAlignment="Right" Margin="0,6,0,0"
                                       MaxWidth="280"
                                       Visibility="{Binding LastError, Converter={StaticResource StringNotEmptyToVis}}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Run-mode segmented -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Run mode" Style="{StaticResource H2}" Margin="0,0,0,6"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" CornerRadius="6,0,0,6"
                                    Background="{Binding IsAuto, Converter={StaticResource BoolToSelectedBg}}">
                                <Button Style="{StaticResource OutlinedButton}" BorderThickness="0"
                                        Background="Transparent" Padding="0,6"
                                        Command="{Binding SelectRunModeCommand}" CommandParameter="auto">
                                    <TextBlock Text="Auto" FontWeight="SemiBold"
                                               Foreground="{Binding IsAuto, Converter={StaticResource BoolToSelectedFg}}"/>
                                </Button>
                            </Border>
                            <Border Grid.Column="1"
                                    Background="{Binding IsManual, Converter={StaticResource BoolToSelectedBg}}">
                                <Button Style="{StaticResource OutlinedButton}" BorderThickness="0"
                                        Background="Transparent" Padding="0,6"
                                        Command="{Binding SelectRunModeCommand}" CommandParameter="manual">
                                    <TextBlock Text="Manual" FontWeight="SemiBold"
                                               Foreground="{Binding IsManual, Converter={StaticResource BoolToSelectedFg}}"/>
                                </Button>
                            </Border>
                            <Border Grid.Column="2" CornerRadius="0,6,6,0"
                                    Background="{Binding IsStartStop, Converter={StaticResource BoolToSelectedBg}}">
                                <Button Style="{StaticResource OutlinedButton}" BorderThickness="0"
                                        Background="Transparent" Padding="0,6"
                                        Command="{Binding SelectRunModeCommand}" CommandParameter="ss">
                                    <TextBlock Text="Start-Stop" FontWeight="SemiBold"
                                               Foreground="{Binding IsStartStop, Converter={StaticResource BoolToSelectedFg}}"/>
                                </Button>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Target stepper -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,8"
                        Visibility="{Binding ShowTargetStepper, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="Target temperature" Style="{StaticResource H2}"/>
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Style="{StaticResource OutlinedButton}"
                                    Content="−" Padding="14,4" FontSize="16"
                                    Command="{Binding NudgeTargetCommand}" CommandParameter="-1"
                                    IsEnabled="{Binding IsReady}"/>
                            <TextBlock Grid.Column="1" Text="{Binding TargetTempC, StringFormat={}{0} °C}"
                                       FontSize="20" FontWeight="SemiBold"
                                       Foreground="{StaticResource InkHi}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Button Grid.Column="2" Style="{StaticResource OutlinedButton}"
                                    Content="+" Padding="14,4" FontSize="16"
                                    Command="{Binding NudgeTargetCommand}" CommandParameter="1"
                                    IsEnabled="{Binding IsReady}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Gear segmented -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,8"
                        Visibility="{Binding ShowGearSegmented, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource H2}">
                            <Run Text="Gear: "/><Run Text="{Binding GearLabel}"/>
                        </TextBlock>
                        <UniformGrid Columns="10" Rows="1" Margin="0,6,0,0">
                            <Button Content="1"  Style="{StaticResource OutlinedButton}" Margin="1"
                                    Command="{Binding PickGearCommand}" CommandParameter="1"  IsEnabled="{Binding IsReady}"/>
                            <Button Content="2"  Style="{StaticResource OutlinedButton}" Margin="1"
                                    Command="{Binding PickGearCommand}" CommandParameter="2"  IsEnabled="{Binding IsReady}"/>
                            <Button Content="3"  Style="{StaticResource OutlinedButton}" Margin="1"
                                    Command="{Binding PickGearCommand}" CommandParameter="3"  IsEnabled="{Binding IsReady}"/>
                            <Button Content="4"  Style="{StaticResource OutlinedButton}" Margin="1"
                                    Command="{Binding PickGearCommand}" CommandParameter="4"  IsEnabled="{Binding IsReady}"/>
                            <Button Content="5"  Style="{StaticResource OutlinedButton}" Margin="1"
                                    Command="{Binding PickGearCommand}" CommandParameter="5"  IsEnabled="{Binding IsReady}"/>
                            <Button Content="6"  Style="{StaticResource OutlinedButton}" Margin="1"
                                    Command="{Binding PickGearCommand}" CommandParameter="6"  IsEnabled="{Binding IsReady}"/>
                            <Button Content="7"  Style="{StaticResource OutlinedButton}" Margin="1"
                                    Command="{Binding PickGearCommand}" CommandParameter="7"  IsEnabled="{Binding IsReady}"/>
                            <Button Content="8"  Style="{StaticResource OutlinedButton}" Margin="1"
                                    Command="{Binding PickGearCommand}" CommandParameter="8"  IsEnabled="{Binding IsReady}"/>
                            <Button Content="9"  Style="{StaticResource OutlinedButton}" Margin="1"
                                    Command="{Binding PickGearCommand}" CommandParameter="9"  IsEnabled="{Binding IsReady}"/>
                            <Button Content="10" Style="{StaticResource OutlinedButton}" Margin="1"
                                    Command="{Binding PickGearCommand}" CommandParameter="10" IsEnabled="{Binding IsReady}"/>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <!-- Action row -->
                <UniformGrid Columns="3" Rows="1">
                    <Button Style="{StaticResource DangerButton}" Content="Heat on"
                            Margin="0,0,4,0" IsEnabled="{Binding IsReady}"
                            Command="{Binding StartCommand}"/>
                    <Button Style="{StaticResource OutlinedButton}" Content="Vent"
                            Margin="2,0,2,0" IsEnabled="{Binding IsReady}"
                            Command="{Binding VentCommand}"/>
                    <Button Style="{StaticResource PrimaryButton}" Content="Stop"
                            Background="{StaticResource ProbeSlate}"
                            Margin="4,0,0,0" IsEnabled="{Binding IsReady}"
                            Command="{Binding StopCommand}"/>
                </UniformGrid>

                <Border CornerRadius="6" Padding="10,6" Margin="0,8,0,0"
                        Background="{StaticResource ErrRed}"
                        Visibility="{Binding FaultLabel, Converter={StaticResource StringNotEmptyToVis}}">
                    <TextBlock Text="{Binding FaultLabel}" Foreground="White" FontWeight="SemiBold"/>
                </Border>

                <!-- Fuel tank card. Tracks current litres, shows hours
                     remaining at the live gear's consumption rate, and
                     surfaces warnings/critical/shutdown banners as the
                     tank empties. Refill and per-heater config (tank
                     size + consumption range) live inline. -->
                <Border Style="{StaticResource Card}" Margin="0,8,0,0">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Fuel" Style="{StaticResource H2}"/>
                            <Button Grid.Column="1" Style="{StaticResource OutlinedButton}"
                                    Content="Refill" Padding="10,3" Margin="0,0,6,0"
                                    Command="{Binding OpenRefillCommand}"/>
                            <Button Grid.Column="2" Style="{StaticResource OutlinedButton}"
                                    Content="⚙" Padding="8,3"
                                    Command="{Binding OpenFuelSettingsCommand}"/>
                        </Grid>

                        <!-- Level + capacity readouts -->
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding FuelLabel}"
                                       FontSize="22" FontWeight="SemiBold"
                                       Foreground="{StaticResource InkHi}"/>
                            <TextBlock Grid.Column="1" Text="{Binding FuelHoursRemainingLabel}"
                                       Style="{StaticResource Caption}" VerticalAlignment="Bottom"/>
                        </Grid>

                        <!-- Visual level bar. Maximum maps to TankLitres,
                             value to CurrentLitres. WPF ProgressBar gives
                             us the gauge feel without a custom control. -->
                        <ProgressBar Margin="0,6,0,0" Height="10"
                                     Minimum="0"
                                     Maximum="{Binding FuelTankLitres}"
                                     Value="{Binding FuelCurrentLitres, Mode=OneWay}"/>

                        <TextBlock Text="{Binding FuelCurrentConsumptionLabel}"
                                   Style="{StaticResource Caption}" Margin="0,6,0,0"/>

                        <!-- Alert banner — colour-coded via FuelAlertKind.
                             Only visible when there's an active alert. -->
                        <Border CornerRadius="6" Padding="10,6" Margin="0,8,0,0"
                                Background="{Binding FuelAlertKind, Converter={StaticResource FuelAlertKindToBrush}}"
                                Visibility="{Binding FuelAlertLabel, Converter={StaticResource StringNotEmptyToVis}}">
                            <TextBlock Text="{Binding FuelAlertLabel}" Foreground="White" FontWeight="SemiBold"/>
                        </Border>

                        <!-- Refill mini-dialog (inline, not a popup so the
                             user keeps the level visible while adjusting). -->
                        <Border CornerRadius="6" Padding="10" Margin="0,8,0,0"
                                Background="{StaticResource Body2}"
                                BorderBrush="{StaticResource LineGrey}" BorderThickness="1"
                                Visibility="{Binding IsRefillOpen, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <TextBlock Text="How many litres did you add?" Style="{StaticResource Body}"/>
                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Padding="6,3"
                                             Text="{Binding RefillLitresInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    <Button Grid.Column="1" Style="{StaticResource OutlinedButton}"
                                            Content="Cancel" Padding="10,3" Margin="6,0,4,0"
                                            Command="{Binding CancelRefillCommand}"/>
                                    <Button Grid.Column="2" Style="{StaticResource PrimaryButton}"
                                            Content="Add" Padding="10,3"
                                            Command="{Binding ApplyRefillCommand}"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Fuel-config mini-dialog: tank size + consumption range. -->
                        <Border CornerRadius="6" Padding="10" Margin="0,8,0,0"
                                Background="{StaticResource Body2}"
                                BorderBrush="{StaticResource LineGrey}" BorderThickness="1"
                                Visibility="{Binding IsFuelSettingsOpen, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <TextBlock Text="Fuel config" Style="{StaticResource H2}"/>
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/><RowDefinition/><RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource Body}"
                                               Text="Tank (L):" VerticalAlignment="Center" Margin="0,0,8,4"/>
                                    <TextBox  Grid.Row="0" Grid.Column="1" Padding="6,3" Margin="0,0,0,4"
                                              Text="{Binding FuelSettingsTankInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource Body}"
                                               Text="Min L/h (gear 1):" VerticalAlignment="Center" Margin="0,0,8,4"/>
                                    <TextBox  Grid.Row="1" Grid.Column="1" Padding="6,3" Margin="0,0,0,4"
                                              Text="{Binding FuelSettingsLowInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource Body}"
                                               Text="Max L/h (gear 10):" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBox  Grid.Row="2" Grid.Column="1" Padding="6,3"
                                              Text="{Binding FuelSettingsHighInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                                    <Button Style="{StaticResource OutlinedButton}"
                                            Content="Cancel" Padding="10,3" Margin="0,0,6,0"
                                            Command="{Binding CancelFuelSettingsCommand}"/>
                                    <Button Style="{StaticResource PrimaryButton}"
                                            Content="Save" Padding="10,3"
                                            Command="{Binding ApplyFuelSettingsCommand}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- RIGHT column: compact stats -->
            <Border Grid.Column="1" Style="{StaticResource Card}" VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock Text="Telemetry" Style="{StaticResource H2}"/>
                    <Grid Margin="0,8,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource Body}" Text="Target"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource Mono}"
                                   Text="{Binding TargetTempC, StringFormat={}{0} °C}"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource Body}" Text="Gear"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource Mono}" Text="{Binding GearLabel}"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource Body}" Text="Housing"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource Mono}" Text="{Binding HousingLabel}"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource Body}" Text="Battery"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource Mono}" Text="{Binding VoltsLabel}"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource Body}" Text="Altitude"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Style="{StaticResource Mono}" Text="{Binding AltitudeLabel}"/>

                        <Border Grid.Row="5" Grid.ColumnSpan="2"
                                BorderBrush="{StaticResource LineGrey}"
                                BorderThickness="0,1,0,0" Margin="0,8,0,8"/>

                        <Button Grid.Row="6" Grid.ColumnSpan="2" Style="{StaticResource OutlinedButton}"
                                Content="Force regInfo read"
                                IsEnabled="{Binding IsReady}"
                                Command="{Binding RefreshCommand}"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
