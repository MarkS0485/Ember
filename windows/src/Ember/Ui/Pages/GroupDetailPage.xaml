<UserControl x:Class="Ember.Ui.Pages.GroupDetailPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="clr-namespace:Ember.Ui.Controls"
             Background="{StaticResource Body0}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <c:BrandTopBar Grid.Row="0" x:Name="TopBar" Title="Group" Subtitle="" ShowBack="True"/>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16">

                <Border Style="{StaticResource Card}" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Members" Style="{StaticResource H2}"/>
                        <ItemsControl x:Name="MemberList" Margin="0,6,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Name}" Style="{StaticResource H2}"/>
                                            <TextBlock Text="{Binding Mac}" Style="{StaticResource Mono}" FontSize="11"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Group actions" Style="{StaticResource H2}"/>
                        <TextBlock Style="{StaticResource Caption}"
                                   Text="Each command is fanned out to every member sequentially (connect → fire → next). Slow with many heaters."/>
                        <UniformGrid Columns="2" Rows="2" Margin="0,8,0,0">
                            <Button Style="{StaticResource DangerButton}" Content="Start all"
                                    Margin="0,0,4,4" Click="OnStartAll"/>
                            <Button Style="{StaticResource PrimaryButton}" Content="Stop all"
                                    Background="{StaticResource ProbeSlate}"
                                    Margin="4,0,0,4" Click="OnStopAll"/>
                            <Button Style="{StaticResource OutlinedButton}" Content="Vent all"
                                    Margin="0,4,4,0" Click="OnVentAll"/>
                            <Button Style="{StaticResource OutlinedButton}" Content="Set target 20 °C"
                                    Margin="4,4,0,0" Click="OnTarget20"/>
                        </UniformGrid>
                        <TextBlock x:Name="ResultLine" Style="{StaticResource Caption}" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Delete group" Style="{StaticResource H2}"/>
                        <Button Style="{StaticResource OutlinedButton}" Content="Delete"
                                Margin="0,8,0,0" HorizontalAlignment="Left"
                                BorderBrush="{StaticResource ErrRed}"
                                Foreground="{StaticResource ErrRed}"
                                Click="OnDelete"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
