<UserControl x:Class="Ember.Ui.Pages.AltitudeProbePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="clr-namespace:Ember.Ui.Controls"
             Background="{StaticResource Body0}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <c:PageHeader Grid.Row="0" Title="Altitude probe"
                      Subtitle="Experimental SHORT_PARA sweep"/>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <Border Background="{StaticResource ErrRed}" CornerRadius="14" Padding="14" Margin="0,0,0,10">
                    <TextBlock Foreground="White" TextWrapping="Wrap"
                               Text="Vendor SHORT_PARA indices are 0–4 only. This screen sweeps higher indices to see if regInfo.altitudeM changes. Most likely the controller ignores them."/>
                </Border>

                <Border Style="{StaticResource Card}" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Read-back from heater" Style="{StaticResource H2}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="altitudeM" Style="{StaticResource Body}"/>
                            <TextBlock x:Name="AltReadBack" Grid.Column="1" Style="{StaticResource Mono}"
                                       Foreground="{StaticResource EmberNavy}" FontSize="15" Text="—"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Altitude value (m)" Style="{StaticResource H2}"/>
                        <TextBox x:Name="AltBox" Text="244" FontSize="16" Padding="8" Margin="0,6,0,0"/>
                        <Slider x:Name="AltSlider" Minimum="-30" Maximum="760" Value="244"
                                Margin="0,8,0,0"
                                ValueChanged="OnSliderChanged"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="SHORT_PARA index" Style="{StaticResource H2}"/>
                        <ComboBox x:Name="IndexCombo" SelectedIndex="0" Margin="0,6,0,0" Padding="8">
                            <ComboBoxItem>5</ComboBoxItem>
                            <ComboBoxItem>6</ComboBoxItem>
                            <ComboBoxItem>7</ComboBoxItem>
                            <ComboBoxItem>8</ComboBoxItem>
                            <ComboBoxItem>9</ComboBoxItem>
                            <ComboBoxItem>10</ComboBoxItem>
                            <ComboBoxItem>11</ComboBoxItem>
                            <ComboBoxItem>12</ComboBoxItem>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Encoding" Style="{StaticResource H2}"/>
                        <ComboBox x:Name="EncodingCombo" SelectedIndex="1" Margin="0,6,0,0" Padding="8">
                            <ComboBoxItem>Single byte (d2)</ComboBoxItem>
                            <ComboBoxItem>uleShort (d1=lo, d2=hi)</ComboBoxItem>
                            <ComboBoxItem>ubeShort (d1=hi, d2=lo)</ComboBoxItem>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Frame preview" Style="{StaticResource H2}"/>
                        <TextBlock x:Name="FramePreview" Style="{StaticResource Mono}" FontSize="14"
                                   Margin="0,6,0,0"/>
                        <Button Style="{StaticResource PrimaryButton}" Content="Send probe frame"
                                Margin="0,10,0,0" Click="OnSend"/>
                        <TextBlock x:Name="ResultLine" Style="{StaticResource Caption}" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
