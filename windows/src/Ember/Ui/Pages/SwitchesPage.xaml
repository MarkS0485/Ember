<UserControl x:Class="Ember.Ui.Pages.SwitchesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="clr-namespace:Ember.Ui.Controls"
             xmlns:vm="clr-namespace:Ember.Ui.ViewModels"
             Background="{StaticResource Body0}">
    <UserControl.DataContext>
        <vm:SwitchesViewModel/>
    </UserControl.DataContext>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <c:PageHeader Grid.Row="0" Title="Switches" Subtitle="Behaviour toggles"/>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="HEATER" Style="{StaticResource Caption}" Margin="4,4,0,6"/>

                <!-- Run mode -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Run mode" Style="{StaticResource H2}"/>
                        <TextBlock Style="{StaticResource Caption}"
                                   Text="Heater chooses output (Auto), fixed gear (Manual), or cycles with hysteresis (Start-Stop)."/>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" CornerRadius="10,0,0,10"
                                    Background="{Binding IsAuto, Converter={StaticResource BoolToSelectedBg}}">
                                <Button Style="{StaticResource BottomTabButton}" Padding="0,10"
                                        Command="{Binding SetRunModeCommand}" CommandParameter="auto">
                                    <TextBlock Text="Auto"
                                               Foreground="{Binding IsAuto, Converter={StaticResource BoolToSelectedFg}}"
                                               HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                </Button>
                            </Border>
                            <Border Grid.Column="1"
                                    Background="{Binding IsManual, Converter={StaticResource BoolToSelectedBg}}">
                                <Button Style="{StaticResource BottomTabButton}" Padding="0,10"
                                        Command="{Binding SetRunModeCommand}" CommandParameter="manual">
                                    <TextBlock Text="Manual"
                                               Foreground="{Binding IsManual, Converter={StaticResource BoolToSelectedFg}}"
                                               HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                </Button>
                            </Border>
                            <Border Grid.Column="2" CornerRadius="0,10,10,0"
                                    Background="{Binding IsStartStop, Converter={StaticResource BoolToSelectedBg}}">
                                <Button Style="{StaticResource BottomTabButton}" Padding="0,10"
                                        Command="{Binding SetRunModeCommand}" CommandParameter="ss">
                                    <TextBlock Text="Start-Stop"
                                               Foreground="{Binding IsStartStop, Converter={StaticResource BoolToSelectedFg}}"
                                               HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                </Button>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Temp unit -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Temperature unit" Style="{StaticResource H2}"/>
                        <TextBlock Style="{StaticResource Caption}"
                                   Text="Changes how the heater's own panel reads. The app always shows °C; active cell mirrors what the heater is reporting."/>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/><ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" CornerRadius="10,0,0,10"
                                    Background="{Binding HeaterShowsF, Converter={StaticResource BoolToSelectedBgInv}}">
                                <Button Style="{StaticResource BottomTabButton}" Padding="0,10"
                                        Command="{Binding SetTempUnitCommand}" CommandParameter="c">
                                    <TextBlock Text="°C" FontFamily="Consolas" FontSize="16"
                                               Foreground="{Binding HeaterShowsF, Converter={StaticResource BoolToSelectedFgInv}}"
                                               HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                </Button>
                            </Border>
                            <Border Grid.Column="1" CornerRadius="0,10,10,0"
                                    Background="{Binding HeaterShowsF, Converter={StaticResource BoolToSelectedBg}}">
                                <Button Style="{StaticResource BottomTabButton}" Padding="0,10"
                                        Command="{Binding SetTempUnitCommand}" CommandParameter="f">
                                    <TextBlock Text="°F" FontFamily="Consolas" FontSize="16"
                                               Foreground="{Binding HeaterShowsF, Converter={StaticResource BoolToSelectedFg}}"
                                               HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                </Button>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <TextBlock Text="APP" Style="{StaticResource Caption}" Margin="4,4,0,6"/>

                <Border Style="{StaticResource Card}" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Keep BLE link alive" Style="{StaticResource H2}"/>
                            <TextBlock Style="{StaticResource Caption}"
                                       Text="Hold the BLE connection while the app is in the background."/>
                        </StackPanel>
                        <CheckBox Grid.Column="1" IsChecked="{Binding KeepAlive}"
                                  Click="OnKeepAliveClick" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <Border Style="{StaticResource Card}" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Auto Start / Stop master" Style="{StaticResource H2}"/>
                            <TextBlock Style="{StaticResource Caption}"
                                       Text="Master switch for app-side automation rules."/>
                        </StackPanel>
                        <CheckBox Grid.Column="1" IsChecked="{Binding AutoStartStopMaster}"
                                  Click="OnAutoMasterClick" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
