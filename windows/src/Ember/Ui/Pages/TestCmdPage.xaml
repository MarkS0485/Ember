<UserControl x:Class="Ember.Ui.Pages.TestCmdPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="clr-namespace:Ember.Ui.Controls"
             Background="{StaticResource Body0}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <c:PageHeader Grid.Row="0" Title="Test commands"
                      Subtitle="Raw BLE frame sender"/>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Hex bytes" Style="{StaticResource H2}" Margin="0,0,0,6"/>
                        <TextBox x:Name="HexBox" Text="AA 00 64 F2 00 05"
                                 FontFamily="Consolas" FontSize="14" Padding="10"
                                 TextWrapping="Wrap" AcceptsReturn="True"
                                 MinHeight="48"/>
                        <UniformGrid Columns="2" Rows="1" Margin="0,10,0,0">
                            <Button Style="{StaticResource PrimaryButton}" Content="Send"
                                    Margin="0,0,4,0" Click="OnSend"/>
                            <Button Style="{StaticResource OutlinedButton}" Content="Compute CRC"
                                    Margin="4,0,0,0" Click="OnComputeCrc"/>
                        </UniformGrid>
                        <TextBlock x:Name="ResultLine" Style="{StaticResource Caption}"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
                <TextBlock Style="{StaticResource Caption}" Margin="4,12,0,0"
                           Text="Whitespace, colons, and commas are stripped. Two hex chars per byte. The frame is sent verbatim — use Compute CRC to recompute the trailing 2 bytes."/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
