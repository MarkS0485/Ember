<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Brand: lifted verbatim from the Android Compose theme so the two
         clients are visually identical. -->
    <Color x:Key="EmberNavyColor">#FF012169</Color>
    <Color x:Key="EmberNavyDkColor">#FF0A1F6B</Color>
    <Color x:Key="EmberRedColor">#FFC8102E</Color>
    <Color x:Key="EmberRedDkColor">#FF9B0D23</Color>
    <Color x:Key="EmberBurgundyColor">#FF6B0C1C</Color>

    <Color x:Key="Body0Color">#FFF1F3F9</Color>
    <Color x:Key="Body1Color">#FFFFFFFF</Color>
    <Color x:Key="Body2Color">#FFF6F7FB</Color>
    <Color x:Key="LineGreyColor">#FFE2E5EE</Color>
    <Color x:Key="LineGreyDkColor">#FFCBD2DF</Color>

    <Color x:Key="InkHiColor">#FF0F172A</Color>
    <Color x:Key="InkMdColor">#FF374151</Color>
    <Color x:Key="InkLoColor">#FF6B7280</Color>

    <Color x:Key="OkGreenColor">#FF16A34A</Color>
    <Color x:Key="WarnAmberColor">#FFD97706</Color>
    <Color x:Key="ErrRedColor">#FFC8102E</Color>

    <Color x:Key="FlameOrangeColor">#FFEA580C</Color>
    <Color x:Key="CoolBlueColor">#FF1D4ED8</Color>
    <Color x:Key="FuelAmberColor">#FFB45309</Color>
    <Color x:Key="ProbeSlateColor">#FF334155</Color>

    <!-- Solid brushes (referenced everywhere) -->
    <SolidColorBrush x:Key="EmberNavy"    Color="{StaticResource EmberNavyColor}"/>
    <SolidColorBrush x:Key="EmberRed"     Color="{StaticResource EmberRedColor}"/>
    <SolidColorBrush x:Key="EmberBurgundy" Color="{StaticResource EmberBurgundyColor}"/>

    <SolidColorBrush x:Key="Body0"       Color="{StaticResource Body0Color}"/>
    <SolidColorBrush x:Key="Body1"       Color="{StaticResource Body1Color}"/>
    <SolidColorBrush x:Key="Body2"       Color="{StaticResource Body2Color}"/>
    <SolidColorBrush x:Key="LineGrey"    Color="{StaticResource LineGreyColor}"/>
    <SolidColorBrush x:Key="LineGreyDk"  Color="{StaticResource LineGreyDkColor}"/>

    <SolidColorBrush x:Key="InkHi"       Color="{StaticResource InkHiColor}"/>
    <SolidColorBrush x:Key="InkMd"       Color="{StaticResource InkMdColor}"/>
    <SolidColorBrush x:Key="InkLo"       Color="{StaticResource InkLoColor}"/>

    <SolidColorBrush x:Key="OkGreen"     Color="{StaticResource OkGreenColor}"/>
    <SolidColorBrush x:Key="WarnAmber"   Color="{StaticResource WarnAmberColor}"/>
    <SolidColorBrush x:Key="ErrRed"      Color="{StaticResource ErrRedColor}"/>

    <SolidColorBrush x:Key="FlameOrange" Color="{StaticResource FlameOrangeColor}"/>
    <SolidColorBrush x:Key="CoolBlue"    Color="{StaticResource CoolBlueColor}"/>
    <SolidColorBrush x:Key="FuelAmber"   Color="{StaticResource FuelAmberColor}"/>
    <SolidColorBrush x:Key="ProbeSlate"  Color="{StaticResource ProbeSlateColor}"/>

    <!-- Brand top-bar gradient: navy → red, same as Android BrandTopBar. -->
    <LinearGradientBrush x:Key="BrandTopBarBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{StaticResource EmberNavyColor}" Offset="0.0"/>
        <GradientStop Color="{StaticResource EmberRedColor}"  Offset="1.0"/>
    </LinearGradientBrush>

</ResourceDictionary>
