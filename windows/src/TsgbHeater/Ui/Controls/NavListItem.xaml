<UserControl x:Class="TsgbHeater.Ui.Controls.NavListItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="self">
    <Button Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand"
            Click="OnClick">
        <Button.Template>
            <ControlTemplate TargetType="Button">
                <Border x:Name="bg" Background="{StaticResource Body1}"
                        BorderBrush="{StaticResource LineGrey}" BorderThickness="1"
                        CornerRadius="14" Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="999"
                                Background="{Binding Accent, ElementName=self}"
                                VerticalAlignment="Center" Margin="0,0,12,0">
                            <TextBlock Text="{Binding Icon, ElementName=self}"
                                       FontFamily="Segoe MDL2 Assets" FontSize="18"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Title, ElementName=self}"
                                       Style="{StaticResource H2}"/>
                            <TextBlock Text="{Binding Subtitle, ElementName=self}"
                                       Style="{StaticResource Caption}"/>
                        </StackPanel>
                        <TextBlock Grid.Column="2" Text="&#xE76C;"
                                   FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   Foreground="{StaticResource InkLo}"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="bg" Property="Background" Value="{StaticResource Body2}"/>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>
        </Button.Template>
    </Button>
</UserControl>
