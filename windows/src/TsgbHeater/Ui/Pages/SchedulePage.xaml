<UserControl x:Class="TsgbHeater.Ui.Pages.SchedulePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="clr-namespace:TsgbHeater.Ui.Controls"
             xmlns:vm="clr-namespace:TsgbHeater.Ui.ViewModels"
             Background="{StaticResource Body0}">

    <UserControl.DataContext>
        <vm:ScheduleViewModel/>
    </UserControl.DataContext>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <c:PageHeader Grid.Row="0" Title="Schedule"
                      Subtitle="Multiple on/off times per day"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Master toggle -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource H2}" Text="Schedule mode"/>
                            <TextBlock Style="{StaticResource Caption}">
                                <Run Text="App-driven scheduler. Pushes the next event into the heater's per-day slot as events fire."/>
                            </TextBlock>
                        </StackPanel>
                        <CheckBox Grid.Column="1" IsChecked="{Binding Enabled}"
                                  Click="OnEnabledClick"
                                  VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Status -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="{Binding StatusLabel}" Style="{StaticResource H2}"
                                   Foreground="{StaticResource TsgbNavy}"/>
                        <TextBlock Text="{Binding StatusDetail}" Style="{StaticResource Caption}"/>
                    </StackPanel>
                </Border>

                <!-- Clear -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Clear heater schedule" Style="{StaticResource H2}"/>
                        <TextBlock Style="{StaticResource Caption}"
                                   Text="Pushes an all-off schedule to the heater. Use this if the heater shows stale times after disabling Schedule mode."/>
                        <Button Style="{StaticResource OutlinedButton}" Content="Clear heater now"
                                Margin="0,8,0,0" HorizontalAlignment="Left"
                                Command="{Binding ClearHeaterCommand}"/>
                    </StackPanel>
                </Border>

                <!-- Per-day editor -->
                <ItemsControl ItemsSource="{Binding Days}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource Card}" Margin="0,0,0,10">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Style="{StaticResource H2}"
                                                   Text="{Binding Label}"/>
                                        <Button Grid.Column="1" Style="{StaticResource OutlinedButton}"
                                                Padding="10,4"
                                                Click="OnAddDay"
                                                Tag="{Binding Day}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets"
                                                           FontSize="14" Margin="0,0,6,0"/>
                                                <TextBlock Text="Add"/>
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding Events}" Margin="0,8,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{StaticResource Body2}"
                                                        CornerRadius="10" Padding="10,8" Margin="0,0,0,6">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Style="{StaticResource Mono}"
                                                                   FontSize="15"
                                                                   Text="{Binding TimeRange}"
                                                                   VerticalAlignment="Center"/>
                                                        <CheckBox Grid.Column="1" IsChecked="{Binding Enabled}"
                                                                  Click="OnToggleEventClick"
                                                                  Tag="{Binding}"
                                                                  Margin="8,0,8,0"
                                                                  VerticalAlignment="Center"/>
                                                        <Button Grid.Column="2" Style="{StaticResource OutlinedButton}"
                                                                Padding="8,4"
                                                                Click="OnDeleteEventClick"
                                                                Tag="{Binding}">
                                                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets"
                                                                       FontSize="13" Foreground="{StaticResource ErrRed}"/>
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
