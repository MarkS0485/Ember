<UserControl x:Class="TsgbHeater.Ui.Pages.ScanPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="clr-namespace:TsgbHeater.Ui.Controls"
             xmlns:vm="clr-namespace:TsgbHeater.Ui.ViewModels"
             Background="{StaticResource Body0}">
    <UserControl.DataContext>
        <vm:ScanViewModel/>
    </UserControl.DataContext>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <c:PageHeader Grid.Row="0" Title="Scan / pair"
                      Subtitle="Pair a heater or reconnect to a known one">
            <c:PageHeader.ActionContent>
                <StackPanel Orientation="Horizontal">
                    <Button Style="{StaticResource OutlinedButton}" Content="Stop"
                            Command="{Binding StopScanCommand}"
                            Visibility="{Binding Scanning, Converter={StaticResource BoolToVis}}"
                            Margin="0,0,6,0"/>
                    <Button Style="{StaticResource PrimaryButton}" Content="Scan"
                            Command="{Binding StartScanCommand}"
                            Visibility="{Binding Scanning, Converter={StaticResource BoolToVisInv}}"/>
                </StackPanel>
            </c:PageHeader.ActionContent>
        </c:PageHeader>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Paired -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,6,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Paired"
                               Style="{StaticResource H2}" Margin="0,0,0,6"/>
                    <TextBlock DockPanel.Dock="Top" Style="{StaticResource Caption}" Margin="0,0,0,8"
                               Text="{Binding LastError}"
                               Foreground="{StaticResource ErrRed}"
                               Visibility="{Binding LastError, Converter={StaticResource StringNotEmptyToVis}}"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <ItemsControl ItemsSource="{Binding Paired}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource Body2}"
                                                CornerRadius="6" Padding="8" Margin="0,0,0,4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding Name}" Style="{StaticResource H2}"/>
                                                    <TextBlock Text="{Binding Mac}" Style="{StaticResource Mono}" FontSize="10"/>
                                                </StackPanel>
                                                <Button Grid.Column="1" Style="{StaticResource OutlinedButton}"
                                                        Content="Connect" Margin="0,0,4,0" Padding="8,3"
                                                        Command="{Binding DataContext.ReconnectCommand,
                                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                                <Button Grid.Column="2" Style="{StaticResource OutlinedButton}"
                                                        Content="Manage" Padding="8,3"
                                                        Click="OnManage" Tag="{Binding Mac}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="No paired heaters yet — scan and bind one on the right."
                                       Style="{StaticResource Caption}" Margin="0,4,0,0"
                                       Visibility="{Binding Paired.Count, Converter={StaticResource CountZeroToVis}}"/>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Discovered -->
            <Border Grid.Column="1" Style="{StaticResource Card}" Margin="6,0,0,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Discovered"
                               Style="{StaticResource H2}" Margin="0,0,0,6"/>
                    <c:StatusPill DockPanel.Dock="Top" HorizontalAlignment="Left" Margin="0,0,0,8"
                                  Label="{Binding StatusLabel}"
                                  Kind="{Binding StatusLabel, Converter={StaticResource StatusLabelToKind}}"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <ItemsControl ItemsSource="{Binding Scanned}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource Body2}"
                                                CornerRadius="6" Padding="8" Margin="0,0,0,4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Style="{StaticResource H2}">
                                                        <Run Text="{Binding Name, FallbackValue='(no name)'}"/>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding Mac}" Style="{StaticResource Mono}" FontSize="10"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Style="{StaticResource Mono}"
                                                           Margin="8,0,8,0" VerticalAlignment="Center">
                                                    <Run Text="{Binding Rssi, StringFormat={}{0} dBm, Mode=OneWay}"/>
                                                </TextBlock>
                                                <Button Grid.Column="2" Style="{StaticResource PrimaryButton}"
                                                        Content="Bind" Padding="10,3"
                                                        Command="{Binding DataContext.BindCommand,
                                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="Tap Scan in the header to look for nearby heaters."
                                       Style="{StaticResource Caption}" Margin="0,4,0,0"
                                       Visibility="{Binding Scanned.Count, Converter={StaticResource CountZeroToVis}}"/>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
