<UserControl x:Class="TsgbHeater.Ui.Pages.AdvancePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="clr-namespace:TsgbHeater.Ui.Controls"
             xmlns:vm="clr-namespace:TsgbHeater.Ui.ViewModels"
             Background="{StaticResource Body0}">
    <UserControl.DataContext>
        <vm:AdvanceViewModel/>
    </UserControl.DataContext>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <c:PageHeader Grid.Row="0" Title="Advanced"
                      Subtitle="Setpoints &amp; hysteresis"/>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <Border Style="{StaticResource Card}" Margin="0,0,0,10">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Target temperature" Style="{StaticResource H2}"/>
                            <TextBlock Grid.Column="1" Style="{StaticResource Mono}" FontSize="18"
                                       Foreground="{StaticResource TsgbNavy}"
                                       Text="{Binding TargetTempC, StringFormat={}{0} °C}"/>
                        </Grid>
                        <Slider Minimum="{Binding TargetMinC}" Maximum="{Binding TargetMaxC}"
                                Value="{Binding TargetTempC}"
                                IsSnapToTickEnabled="True" TickFrequency="1"
                                IsEnabled="{Binding IsReady}" Margin="0,8,0,0"/>
                        <TextBlock Style="{StaticResource Caption}"
                                   Text="Range 10–35 °C. The heater clamps to its supported range in your current unit."/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Start-Stop hysteresis" Style="{StaticResource H2}"/>
                            <TextBlock Grid.Column="1" Style="{StaticResource Mono}" FontSize="18"
                                       Foreground="{StaticResource TsgbNavy}"
                                       Text="{Binding TempDiffC, StringFormat={}{0} °C}"/>
                        </Grid>
                        <Slider Minimum="{Binding DiffMinC}" Maximum="{Binding DiffMaxC}"
                                Value="{Binding TempDiffC}"
                                IsSnapToTickEnabled="True" TickFrequency="1"
                                IsEnabled="{Binding IsReady}" Margin="0,8,0,0"/>
                        <TextBlock Style="{StaticResource Caption}"
                                   Text="In Start-Stop mode, how far the heater lets the room drift above target before cutting the burn (3–15 °C)."/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
